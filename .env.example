# ─── Required ─────────────────────────────────────────────────────────────────
# Your chosen auth token — clients must send this as: Authorization: Bearer <value>
PROXY_API_KEY=your-secret-token-here

# ─── Option A: Replit AI Integrations (auto-provisioned, no action needed) ───
# These are set automatically when you enable the integrations on Replit.
# AI_INTEGRATIONS_OPENAI_BASE_URL=
# AI_INTEGRATIONS_OPENAI_API_KEY=
# AI_INTEGRATIONS_ANTHROPIC_BASE_URL=
# AI_INTEGRATIONS_ANTHROPIC_API_KEY=

# ─── Option B: Standard API keys (for non-Replit deployments) ────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1   # optional, only for custom endpoints

# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com  # optional, only for custom endpoints
